{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blackbox ticket closure result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ticket_id",
    "result",
    "documentation_files_changed",
    "manual_verification_recorded",
    "application_files_changed",
    "summary"
  ],
  "properties": {
    "ticket_id": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": ["CLOSED", "BLOCKED", "PARTIAL"]
    },
    "documentation_files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manual_verification_recorded": {
      "type": "boolean"
    },
    "application_files_changed": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    }
  }
}
