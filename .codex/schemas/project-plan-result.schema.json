{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blackbox project planning result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "result",
    "summary",
    "tickets",
    "created_files",
    "validation",
    "implementation_started",
    "next_action"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["dry-run", "execute"]
    },
    "result": {
      "type": "string",
      "enum": ["PROPOSED", "DRAFTS_CREATED", "BLOCKED", "VALIDATION_BLOCKED"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tickets": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "slug",
          "title",
          "status",
          "outcome",
          "reason",
          "dependencies",
          "preconditions",
          "allowed_scope",
          "protected_areas",
          "requirements",
          "acceptance_criteria",
          "automated_checks",
          "manual_verification",
          "exclusions",
          "documentation_required",
          "rollback",
          "reviewer_focus"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T[0-9]{4}$"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "title": {"type": "string", "minLength": 1},
          "status": {"type": "string", "const": "Draft"},
          "outcome": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "dependencies": {
            "type": "array",
            "items": {"type": "string", "pattern": "^T[0-9]{4}$"}
          },
          "preconditions": {"$ref": "#/$defs/nonEmptyStrings"},
          "allowed_scope": {"$ref": "#/$defs/nonEmptyStrings"},
          "protected_areas": {"$ref": "#/$defs/nonEmptyStrings"},
          "requirements": {"$ref": "#/$defs/nonEmptyStrings"},
          "acceptance_criteria": {"$ref": "#/$defs/nonEmptyStrings"},
          "automated_checks": {"$ref": "#/$defs/nonEmptyStrings"},
          "manual_verification": {"$ref": "#/$defs/nonEmptyStrings"},
          "exclusions": {"$ref": "#/$defs/nonEmptyStrings"},
          "documentation_required": {"$ref": "#/$defs/nonEmptyStrings"},
          "rollback": {"type": "string", "minLength": 1},
          "reviewer_focus": {"$ref": "#/$defs/nonEmptyStrings"}
        }
      }
    },
    "created_files": {
      "type": "array",
      "maxItems": 3,
      "items": {"type": "string"}
    },
    "validation": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ticket_id", "result", "summary"],
        "properties": {
          "ticket_id": {"type": "string", "pattern": "^T[0-9]{4}$"},
          "result": {"type": "string", "enum": ["GO", "BLOCKED", "NOT_RUN"]},
          "summary": {"type": "string"}
        }
      }
    },
    "implementation_started": {"type": "boolean", "const": false},
    "next_action": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
