{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blackbox ticket review result",
  "type": "object",
  "additionalProperties": false,
  "required": ["ticket_id", "result", "summary", "findings"],
  "properties": {
    "ticket_id": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": ["PASS", "PASS_WITH_NONBLOCKING_FINDINGS", "BLOCKED"]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "path",
          "line",
          "explanation",
          "recommended_action"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "MUST_FIX", "SHOULD_FIX", "OPTIONAL"]
          },
          "title": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "line": {
            "type": ["integer", "null"]
          },
          "explanation": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          }
        }
      }
    }
  }
}
