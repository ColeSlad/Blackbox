{
  "name": "blackbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "10.31.0"
  },
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:server": "pnpm --filter @blackbox/server dev",
    "dev:worker": "pnpm --filter @blackbox/worker dev",
    "dev:web": "pnpm --filter @blackbox/web dev",
    "format": "prettier --write --ignore-unknown apps packages fixtures scripts/verification .github/workflows/verify.yml package.json pnpm-workspace.yaml eslint.config.js README.md",
    "format:check": "prettier --check --ignore-unknown apps packages fixtures scripts/verification .github/workflows/verify.yml package.json pnpm-workspace.yaml eslint.config.js README.md",
    "lint": "eslint apps packages fixtures scripts/verification",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:integration": "node --test scripts/verification/integration-smoke.mjs",
    "build": "pnpm -r --if-present build",
    "verify": "node scripts/verification/run-verification.mjs"
  },
  "dependencies": {
    "@blackbox/cli": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
